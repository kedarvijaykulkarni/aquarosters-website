NEXT_PUBLIC_SITE_URL=https://aquarosters.com
NEXT_PUBLIC_DEMO_EMAIL=hello@aquarosters.com
# Form backend endpoint (e.g. a Formspree/Getform form URL) that accepts a POST
# with Accept: application/json. Leave unset to show the email fallback instead.
NEXT_PUBLIC_FORM_ENDPOINT=

# Supabase project used by the Contact and Design Partner forms (see
# docs/SUPABASE_FORMS.md). The anon/publishable key is safe to expose in the
# browser bundle. It can no longer insert into the form tables directly —
# submissions go through the submit-public-form Edge Function instead.
NEXT_PUBLIC_SUPABASE_URL=https://kocqprhhqrrfirwpxbtn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_publishable_key

# Cloudflare Turnstile site key — safe to expose in the browser, it only
# renders the challenge widget. Get it from the Cloudflare dashboard after
# creating a Turnstile widget for this domain (see docs/SUPABASE_FORMS.md).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_with_cloudflare_turnstile_site_key

# --- Supabase Edge Function secrets only. Do NOT expose these in the browser,
# do NOT read them from Next.js code, and do NOT set them here for real. They
# are listed for reference only — set the real values with:
#   supabase secrets set TURNSTILE_SECRET_KEY=your_turnstile_secret_key
#   supabase secrets set ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com
# TURNSTILE_SECRET_KEY=replace_with_cloudflare_turnstile_secret_key
# ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com
